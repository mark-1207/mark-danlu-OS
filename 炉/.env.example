# 炉 (Lu) 环境变量示例
# 复制本文件为 .env 并填入真实 key（.env 已 gitignored，不会提交）

# 主要 LLM Provider：OpenAI-compatible（mimo 节点）
# run 命令：--provider openai 时使用，fallback 顺序：mimo → kimi → nvidia
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 主要 chat 模型（当 BASE_URL 为 mimo 节点时使用）
MIMO_MODEL_LIGHT=mimo-v2-flash
MIMO_MODEL_HEAVY=mimo-v2-pro

# LLM Fallback：Kimi
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

# LLM Fallback：NVIDIA NIM（OpenAI-compatible）
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=nvidia/nemotron-4-340b-instruct

# OpenRouter fallback 备用（LLM + embedding 都可用）
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Zhipu 智谱（Embedding Primary，OpenAI-compatible 端点）
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Embedding 默认配置
# fallback 顺序：智谱 → 英伟达 → OpenRouter
LU_EMBEDDING_API_KEY=${ZHIPU_API_KEY}
LU_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LU_EMBEDDING_MODEL=embedding-3

LU_EMBEDDING_FALLBACK_1_API_KEY=${NVIDIA_API_KEY}
LU_EMBEDDING_FALLBACK_1_BASE_URL=https://integrate.api.nvidia.com/v1
LU_EMBEDDING_FALLBACK_1_MODEL=nvidia/nv-embedqa-e5-v5

LU_EMBEDDING_FALLBACK_2_API_KEY=${OPENROUTER_API_KEY}
LU_EMBEDDING_FALLBACK_2_BASE_URL=https://openrouter.ai/api/v1
LU_EMBEDDING_FALLBACK_2_MODEL=openai/text-embedding-3-small

# 搜索 API（素材检索）
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# 飞书多维表格
FEISHU_TOPIC_TABLE_APP_TOKEN=your_app_token
FEISHU_TOPIC_TABLE_ID=your_table_id
FEISHU_FEEDBACK_TABLE_APP_TOKEN=your_app_token
FEISHU_FEEDBACK_TABLE_ID=your_table_id
FEISHU_VIRAL_LIBRARY_APP_TOKEN=your_app_token
FEISHU_VIRAL_LIBRARY_TABLE_ID=your_table_id
