{
  "permissions": {
    "allow": [
      "Bash(path:*)",
      "WebSearch",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(echo:*)",
      "Bash(~/.bashrc << 'EOF'\n# Claude Code alias - bypass permissions\nalias claude='claude --dangerously-skip-permissions'\n\n# 如果你之前有其他配置，保留在下面\nEOF)",
      "Bash(source:*)",
      "Bash(alias:*)",
      "Bash(npx skills-installer install:*)",
      "Bash(npm install:*)",
      "Bash(npx skills:*)",
      "Bash(grep -r \"data:base:record:readonly\\\\|docx:document\\\\|drive:drive\\\\|sheets:spreadsheet\\\\|calendar:calendar\\\\|task:task\" ~/.agents/skills/lark-* --include=\"*.md\")",
      "Bash(grep -rho '\"[a-z:_=>*-]\\\\{10,\\\\}\"' ~/.agents/skills/lark-*/SKILL.md)",
      "Bash(grep -rh \"scope\\\\|permission\" ~/.agents/skills/lark-*/SKILL.md)",
      "Bash(grep -rh \"open-apis\\\\|bitable/v1\\\\|drive/v1\\\\|docx/v1\\\\|sheets/v1\\\\|calendar/v1\" ~/.agents/skills/lark-*/SKILL.md)",
      "Bash(grep -rh \"\\\\-\\\\-domain\\\\|--domain\\\\|domain:\" ~/.agents/skills/lark-*/SKILL.md)",
      "Bash(lark-cli auth:*)",
      "Bash(lark-cli --help)",
      "Bash(lark-cli config:*)",
      "Bash(lark-cli base:*)",
      "Bash(lark-cli wiki:*)",
      "Bash(lark-cli drive:*)",
      "Bash(lark-cli api:*)",
      "Bash(lark-cli search:*)"
    ]
  }
}
